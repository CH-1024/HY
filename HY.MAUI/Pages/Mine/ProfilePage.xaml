<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HY.MAUI.Pages.Mine.ProfilePage"
             x:Name="_ProfilePage"
             Shell.NavBarIsVisible="{OnIdiom Phone=True, Desktop=True}"
             Shell.TabBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:pm="clr-namespace:HY.MAUI.PageModels.Mine"
             xmlns:m="clr-namespace:HY.MAUI.Models"
             x:DataType="pm:ProfilePageModel">

    
    <ContentPage.Resources>
        <ResourceDictionary>

            <Style x:Key="IconBtn1" TargetType="Button">
                <Setter Property="MinimumHeightRequest" Value="0"/>
                <Setter Property="MinimumWidthRequest" Value="0"/>
                <Setter Property="HeightRequest" Value="{OnIdiom Desktop=50, Phone=60}"/>
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Dark=#111111, Light=#EEEEEE}"/>
                <Setter Property="ContentLayout" Value="Top,0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="FontSize" Value="Micro"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="HorizontalOptions" Value="Fill"/>
                <Setter Property="VerticalOptions" Value="Fill"/>
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>
    

    <ContentPage.Behaviors>
        <!--<toolkit:EventToCommandBehavior EventName="NavigatedTo" Command="{Binding NavigatedToCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _ProfilePage}, x:DataType=ContentPage}"/>-->
        <!--<toolkit:EventToCommandBehavior EventName="NavigatedFrom" Command="{Binding NavigatedFromCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _ProfilePage}, x:DataType=ContentPage}"/>-->
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding AppearingCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _ProfilePage}, x:DataType=ContentPage}" />
        <!--<toolkit:EventToCommandBehavior EventName="Disappearing" Command="{Binding DisappearingCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _ProfilePage}, x:DataType=ContentPage}" />-->
    </ContentPage.Behaviors>

    <!--<Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False" IsVisible="False" />
    </Shell.BackButtonBehavior>
    <Shell.TitleView>
        <Grid ColumnDefinitions="50,*,50">
            <Button HeightRequest="40" Grid.Column="0" Text="＜" Command="{Binding GoBackCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _ProfilePage}, x:DataType=ContentPage}" TextColor="Gray" FontSize="Title" FontAttributes="Bold" BackgroundColor="Transparent" HorizontalOptions="Start" VerticalOptions="Center" Padding="0" Margin="0"/>
            <Label  HeightRequest="40" Grid.Column="1" Text="个人资料" TextColor="{StaticResource PrimaryDark}" FontSize="Title" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
            <Button HeightRequest="40" Grid.Column="2" Text="…" Clicked="Button_Clicked" TextColor="Gray" FontSize="Title" FontAttributes="Bold" BackgroundColor="Transparent" HorizontalOptions="End" VerticalOptions="Center" Padding="0" Margin="0"/>

            <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#292929" VerticalOptions="End"/>
        </Grid>
    </Shell.TitleView>-->

    <Shell.TitleView>
        <Label Text="个人资料" TextColor="{StaticResource PrimaryDark}" FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Title"/>
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="编辑" Order="Secondary" Priority="0"/>
        <ToolbarItem Text="更换头像" Order="Secondary" Priority="1" Command="{Binding ChangeAvatarCommand}"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <toolkit:AvatarView ImageSource="{Binding CurrentUser.Avatar}" BackgroundColor="Black" Stroke="Transparent" CornerRadius="18" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" VerticalOptions="Center" Padding="0" Margin="0"/>

             <!--头像 
            <Grid HorizontalOptions="Center">

                <toolkit:AvatarView ImageSource="{Binding CurrentUser.Avatar}" BackgroundColor="Black" Stroke="Transparent" CornerRadius="18" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" VerticalOptions="Center" Padding="0" Margin="0"/>

                 更换头像按钮 
                <Button Text="✎" WidthRequest="36" HeightRequest="36" CornerRadius="18" FontSize="30" Padding="0" FontAttributes="Bold" HorizontalOptions="End" VerticalOptions="End" Command="{Binding ChangeAvatarCommand}"/>
            </Grid>-->

            <!-- 姓名 -->
            <VerticalStackLayout>
                <Label Text="姓名" FontSize="14" TextColor="Gray"/>
                <Entry Text="{Binding RealName}" Placeholder="请输入姓名"/>
            </VerticalStackLayout>

            <!-- 昵称 -->
            <VerticalStackLayout>
                <Label Text="昵称" FontSize="14" TextColor="Gray"/>
                <Entry Text="{Binding NickName}" Placeholder="请输入昵称"/>
            </VerticalStackLayout>

            <!-- 备注 -->
            <VerticalStackLayout>
                <Label Text="备注" FontSize="14" TextColor="Gray"/>
                <Editor Text="{Binding Remark}" Placeholder="备注信息" AutoSize="TextChanges" HeightRequest="100"/>
            </VerticalStackLayout>

            <!-- 保存按钮 -->
            <Button Style="{StaticResource IconBtn1}" Text="保存" Command="{Binding SaveCommand}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
