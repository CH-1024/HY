    <Shell.TitleView>
        <Label Text="联系人资料" TextColor="{StaticResource PrimaryDark}" FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Title"/>
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="备注" Order="Secondary" Priority="0" />
        <ToolbarItem Text="拉黑" Order="Secondary" Priority="0" />
        <ToolbarItem Text="删除" Order="Secondary" Priority="1" />
    </ContentPage.ToolbarItems>


    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="20">

            <!-- 头像 + 昵称 -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                <toolkit:AvatarView ImageSource="{Binding ContactInfo.Avatar}" BackgroundColor="Black" Stroke="Transparent" CornerRadius="18" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" VerticalOptions="Center" Padding="0" Margin="0"/>

                <Label
                    Text="{Binding ContactInfo.Nickname}"
                    FontSize="20"
                    HorizontalOptions="Center"
                    FontAttributes="Bold"/>
            </VerticalStackLayout>

            <!-- 信息卡片 -->
            <Border StrokeShape="RoundRectangle 10" Padding="15">
                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="50,*">
                        <Label Text="HYID：" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="{Binding ContactInfo.HYid}"/>
                    </Grid>

                    <Grid ColumnDefinitions="50,*">
                        <Label Text="状态：" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="{Binding ContactInfo.Relation_Status}"/>
                    </Grid>

                    <Grid ColumnDefinitions="50,*">
                        <Label Text="地区：" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="{Binding ContactInfo.Region}"/>
                    </Grid>

                    <Grid ColumnDefinitions="50,*">
                        <Label Text="备注：" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="{Binding ContactInfo.Remark}" LineBreakMode="WordWrap"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- 操作按钮 -->
            <VerticalStackLayout Spacing="10">
                <Button Style="{StaticResource IconBtn1}" Text="发消息" Command="{Binding SendMessageCommand}"/>

                <Button Style="{StaticResource IconBtn1}" Text="音视频通话"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
    
    
