<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HY.MAUI.Pages.Login.LoginPage"
             x:Name="_LoginPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:pm="clr-namespace:HY.MAUI.PageModels.Login"
             xmlns:m="clr-namespace:HY.MAUI.Models"
             x:DataType="pm:LoginPageModel">

    <ContentPage.Behaviors>
        <!--<toolkit:EventToCommandBehavior EventName="NavigatedTo" Command="{Binding NavigatedToCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _LoginPage}, x:DataType=ContentPage}"/>-->
        <!--<toolkit:EventToCommandBehavior EventName="NavigatedFrom" Command="{Binding NavigatedFromCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _LoginPage}, x:DataType=ContentPage}"/>-->
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding AppearingCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _LoginPage}, x:DataType=ContentPage}" />
        <!--<toolkit:EventToCommandBehavior EventName="Disappearing" Command="{Binding DisappearingCommand}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _LoginPage}, x:DataType=ContentPage}" />-->
    </ContentPage.Behaviors>

    <ScrollView>
        <Grid>
            <VerticalStackLayout Padding="40" Spacing="20">

                <Label Text="登录" FontSize="24" />

                <Entry Text="{Binding Username}" Placeholder="用户名" />
                <Entry Text="{Binding Password}" Placeholder="密码" IsPassword="True" />

                <Button Text="登录" Command="{Binding LoginCommand}"/>
                <Button Text="注册" Command="{Binding RegisterCommand}"/>
            </VerticalStackLayout>
            <ActivityIndicator IsRunning="{Binding LoginCommand.IsRunning}" Color="White" HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>
    </ScrollView>

</ContentPage>
