    </Shell.TitleView>-->


    <Shell.TitleView>
        <Label Text="{Binding Title}" TextColor="{StaticResource PrimaryDark}" FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="Title"/>
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="查找聊天内容" Order="Secondary" Priority="0" />
        <ToolbarItem Text="消息免打扰" Order="Secondary" Priority="1" />
        <ToolbarItem Text="提醒" Order="Secondary" Priority="2" />
        <ToolbarItem Text="清空聊天记录" Order="Secondary" Priority="3" />
        <ToolbarItem Text="弹出测试" Order="Secondary" Priority="4" Clicked="Button_Clicked"/>
    </ContentPage.ToolbarItems>




    <Grid RowDefinitions="*, auto, auto">

        <!--<CollectionView x:Name="collectionView" ItemsSource="{Binding MessageCollection}" SelectionMode="None" ItemsUpdatingScrollMode="KeepLastItemInView" Margin="5">

            <CollectionView.GestureRecognizers>
                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
            </CollectionView.GestureRecognizers>

            <CollectionView.Behaviors>
                <toolkit:EventToCommandBehavior EventName="Scrolled" Command="{Binding ScrolledCommand}" CommandParameter="{Binding Source={x:Reference collectionView}}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _MessagePage}, x:DataType=CollectionView}"/>
                <toolkit:EventToCommandBehavior EventName="Loaded" Command="{Binding CollectionViewLoadedCommand}" CommandParameter="{Binding Source={x:Reference collectionView}}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _MessagePage}, x:DataType=CollectionView}"/>
