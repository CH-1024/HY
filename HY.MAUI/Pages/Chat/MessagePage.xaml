                            </toolkit:AvatarView.GestureRecognizers>
                        </toolkit:AvatarView>

                        <Label Grid.Column="1" Text="{Binding Content}" FontSize="Micro" MinimumHeightRequest="34" MinimumWidthRequest="0" HorizontalOptions="{Binding Content_Horizontal}" BackgroundColor="Black"/>

