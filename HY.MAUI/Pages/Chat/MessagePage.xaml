        <ActivityIndicator IsRunning="True" IsVisible="{Binding RefreshCommand.IsRunning}" ZIndex="2" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,0,0,0"/>

        <CollectionView x:Name="collectionView" ItemsSource="{Binding MessageCollection}" SelectionMode="None" ItemsUpdatingScrollMode="KeepScrollOffset">

            <CollectionView.Behaviors>
                <toolkit:EventToCommandBehavior EventName="Loaded" Command="{Binding CollectionViewLoadedCommand}" CommandParameter="{Binding Source={x:Reference collectionView}}" BindingContext="{Binding Path=BindingContext, Source={x:Reference _MessagePage}, x:DataType=ContentPage}"/>
                <toolkit:EventToCommandBehavior EventName="Scrolled" Command="{Binding CollectionViewScrolledCommand}" x:TypeArguments="ItemsViewScrolledEventArgs" BindingContext="{Binding Path=BindingContext, Source={x:Reference _MessagePage}, x:DataType=ContentPage}"/>
            </CollectionView.Behaviors>

            <CollectionView.GestureRecognizers>
                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
            </CollectionView.GestureRecognizers>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" SnapPointsType="Mandatory"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <controls:MessageTemplateSelector>

                    <controls:MessageTemplateSelector.TextTemplate>
                        <DataTemplate x:DataType="msgvm:TextMessageVM">
                            <controls:TextBubble Command="{Binding Path=BindingContext.InvocationCommand, Source={x:Reference _MessagePage}}"/>
                        </DataTemplate>
                    </controls:MessageTemplateSelector.TextTemplate>

                    <controls:MessageTemplateSelector.ImageTemplate>
                        <DataTemplate x:DataType="msgvm:ImageMessageVM">
                            <controls:ImageBubble Command="{Binding Path=BindingContext.InvocationCommand, Source={x:Reference _MessagePage}}"/>
                        </DataTemplate>
                    </controls:MessageTemplateSelector.ImageTemplate>

                    <controls:MessageTemplateSelector.VoiceTemplate>
                        <DataTemplate x:DataType="msgvm:VoiceMessageVM">

                        </DataTemplate>
                    </controls:MessageTemplateSelector.VoiceTemplate>

                    <controls:MessageTemplateSelector.SystemTemplate>
                        <DataTemplate x:DataType="msgvm:SystemMessageVM">
                            <controls:SystemBubble/>
                        </DataTemplate>
                    </controls:MessageTemplateSelector.SystemTemplate>

                </controls:MessageTemplateSelector>
            </CollectionView.ItemTemplate>
        </CollectionView>

        
        <Border IsVisible="{Binding ShowUnread}" StrokeThickness="0" StrokeShape="RoundRectangle 20,0,20,0" HorizontalOptions="End" VerticalOptions="End" Margin="20,20,0,20" Opacity="0.9">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,0" Radius="20" Opacity="1"/>
            </Border.Shadow>

            <Button Text="{Binding UnreadCount,StringFormat='⇊{0}条新消息'}" Command="{Binding ShowBottomCommand}" BackgroundColor="Gray" CornerRadius="0" Padding="10" HeightRequest="40"/>
        </Border>
        

        <!--底部栏-->
        <Grid Grid.Row="1" ColumnDefinitions="auto,*,auto,auto" ColumnSpacing="5" BackgroundColor="#141414" Padding="10" MinimumHeightRequest="0">

            <Button Style="{StaticResource IconBtn1}" Text="录" Grid.Column="0" Clicked="Record_Btn_Clicked"/>

            <controls:ChatEditor Grid.Column="1" Text="{Binding InputText}" SendCommand="{Binding SendTextCommand}" AutoSize="TextChanges" Keyboard="Chat" MaxLength="500" MaximumHeightRequest="300" BackgroundColor="#2F2F2F" TextColor="White" FontSize="Micro" />

            <Button Style="{StaticResource IconBtn1}" Text="折" Grid.Column="2" Clicked="Switch_Expander_Clicked"/>

            <Button Style="{StaticResource IconBtn1}" Text="发" Grid.Column="3" Clicked="Send_Text_Clicked"/>

        </Grid>


        <!--弹出栏-->
        <toolkit:UniformItemsLayout x:Name="expander" Grid.Row="2" Padding="0" Margin="0" HeightRequest="0" IsClippedToBounds="True">

            <Button Style="{StaticResource IconBtn2}" Text="发送图片" Clicked="Send_Image_Clicked"/>

            <Button Style="{StaticResource IconBtn2}" Text="发送视频" Command="{Binding VideoCommand}" CommandParameter="{Binding Source={x:Reference expander}}"/>

            <Button Style="{StaticResource IconBtn2}" Text="拍摄图片" Command="{Binding TakePhotoCommand}" CommandParameter="{Binding Source={x:Reference expander}}"/>

            <Button Style="{StaticResource IconBtn2}" Text="拍摄视频" Command="{Binding TakeVideoCommand}" CommandParameter="{Binding Source={x:Reference expander}}"/>

            <Button Style="{StaticResource IconBtn2}" Text="语音电话" Command="{Binding AudioCallCommand}" CommandParameter="{Binding Source={x:Reference expander}}"/>

            <Button Style="{StaticResource IconBtn2}" Text="视频电话" Command="{Binding VideoCallCommand}" CommandParameter="{Binding Source={x:Reference expander}}"/>

        </toolkit:UniformItemsLayout>


    </Grid>

</ContentPage>
