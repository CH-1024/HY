<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="HY.MAUI.Pages.Chat.Popups.AnimPopup1"
    x:Name="popup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"
    Margin="0" Padding="0" BackgroundColor="Transparent"
    CanBeDismissedByTappingOutsideOfPopup="False">



    <Grid RowDefinitions="*,Auto" Loaded="OnAnimateEntry">

        <!-- 点击遮罩 -->
        <BoxView Grid.Row="0" BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAnimateExit"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- 真正的底部弹窗 -->
        <Border x:Name="content" Grid.Row="1" BackgroundColor="Black" StrokeThickness="0" StrokeShape="RoundRectangle 10,10,0,0" Margin="0,0,0,-30" HeightRequest="{Binding Source={x:Reference popup}, Path=PopLength}" TranslationY="{Binding Source={x:Reference popup}, Path=PopLength}">
            <VerticalStackLayout Padding="20">
                <Label Text="Hello, World!" />
                <Button Text="Done" Clicked="OnAnimateExit"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
    
</toolkit:Popup>
