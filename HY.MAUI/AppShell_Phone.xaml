<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HY.MAUI.AppShell_Phone"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HY.MAUI"
    xmlns:chat="clr-namespace:HY.MAUI.Pages.Chat"
    xmlns:contact="clr-namespace:HY.MAUI.Pages.Contact"
    xmlns:mine="clr-namespace:HY.MAUI.Pages.Mine"
    Shell.FlyoutBehavior="Disabled"
    Title="HY.MAUI">

    <Shell.ItemTemplate>
        <DataTemplate>
            <Image Source="{Binding FlyoutIcon}" Margin="0" Aspect="AspectFit" HeightRequest="45" WidthRequest="45" HorizontalOptions="Start" VerticalOptions="Center"/>

            <!--<Grid ColumnDefinitions="35,60">
                <Image Source="{Binding FlyoutIcon}" Margin="5" HeightRequest="35" WidthRequest="35" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="{Binding Title}" HeightRequest="45" WidthRequest="80" VerticalTextAlignment="Center" />
            </Grid>-->

        </DataTemplate>
    </Shell.ItemTemplate>

    <TabBar>
        <ShellContent Title="Chat" FlyoutIcon="dotnet_bot.png" ContentTemplate="{DataTemplate chat:ChatPage}" />

        <ShellContent Title="Contact" FlyoutIcon="dotnet_bot.png"  ContentTemplate="{DataTemplate contact:ContactPage}" />

        <ShellContent Title="Mine" FlyoutIcon="dotnet_bot.png" ContentTemplate="{DataTemplate mine:MinePage}" />
    </TabBar>

</Shell>
